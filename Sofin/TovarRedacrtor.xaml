<Window x:Class="Sofin.TovarRedacrtor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Товар"
        Height="600"
        Width="500"
        FontFamily="Calibri"
        FontSize="13">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <StackPanel>

                <TextBlock Text="ID"/>
                <TextBox x:Name="tbId"
                         IsReadOnly="True"
                         Margin="0,3,0,10"/>

                <TextBlock Text="Название"/>
                <TextBox x:Name="tbName"
                         Margin="0,3,0,10"/>

                <TextBlock Text="Категория"/>
                <ComboBox x:Name="cbCategory"
                          Margin="0,3,0,10"/>

                <TextBlock Text="Производитель"/>
                <ComboBox x:Name="cbManufacturer"
                          Margin="0,3,0,10"/>

                <TextBlock Text="Поставщик"/>
                <ComboBox x:Name="cbSupplier"
                          Margin="0,3,0,10"/>

                <TextBlock Text="Ед. изм"/>
                <ComboBox x:Name="cbUnit"
                          Margin="0,3,0,10"/>

                <TextBlock Text="Описание"/>
                <TextBox x:Name="tbDescription"
                         Height="100"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Margin="0,3,0,10"/>

                <TextBlock Text="Цена"/>
                <TextBox x:Name="tbCost"
                         Margin="0,3,0,10"/>

                <TextBlock Text="Артикул"/>
                <TextBox x:Name="tbArticle"
                         Margin="0,3,0,10"/>

                <TextBlock Text="Склад"/>
                <TextBox x:Name="tbStock"
                         Margin="0,3,0,10"/>

                <TextBlock Text="Скидка %"/>
                <TextBox x:Name="tbDiscount"
                         Margin="0,3,0,10"/>

            </StackPanel>

        </ScrollViewer>

        <Button Grid.Row="1"
                Content="Сохранить"
                Height="40"
                HorizontalAlignment="Stretch"
                Margin="0,5,0,0"
                Click="Save_Click"/>

    </Grid>
</Window>